{
  "name": "giftme",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "workspaces": [
    "functions"
  ],
  "scripts": {
    "start": "expo start --clear",
    "dev": "expo start --dev-client --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit && npm --workspace functions run typecheck",
    "build:functions": "npm --workspace functions run build",
    "emulators": "npm run build:functions && firebase emulators:start --project demo-giftme",
    "test:backend": "npm run build:functions && firebase emulators:exec --project demo-giftme --only auth,firestore,functions,storage \"vitest run\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^15.0.0",
    "expo": "~55.0.0",
    "expo-apple-authentication": "~8.0.7",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.9",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.8",
    "expo-router": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "firebase": "^11.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "eslint": "^9.30.0",
    "eslint-config-expo": "^10.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
